{
  "name": "mayclemay-messenger",
  "version": "1.0.0",
  "description": "MaycleMay Desktop Messenger",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "cloud-server": "node cloud-server.js",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.mayclemay.messenger",
    "productName": "MaycleMay",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "assets/icon.png"
    }
  },
  "keywords": ["messenger", "chat"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "socket.io": "^4.6.0",
    "socket.io-client": "^4.6.0",
    "express": "^4.18.0",
    "cors": "^2.8.5"
  }
}
